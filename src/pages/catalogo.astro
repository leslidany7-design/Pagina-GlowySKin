---
/**
 * catalogo.astro — Independent Catalog page showing all products with advanced filters
 */
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons.astro';

// Interactive React islands
import CatalogGrid from '../components/react/CatalogGrid';
import DiscountBanner from '../components/react/DiscountBanner';
import CartDrawer from '../components/react/CartDrawer';
import ProfileDrawer from '../components/react/ProfileDrawer';
import SearchBar from '../components/react/SearchBar';
import Toast from '../components/react/Toast';
---

<Layout title="Catálogo — GLOWYSKIN K-Beauty Premium Chile" description="Explora toda nuestra colección de cosmética coreana prestigiosa. Filtra por categoría, marca e ingrediente con envíos a todo Chile.">
  <!-- Global Toast Notifications -->
  <Toast client:load />

  <!-- Navbar -->
  <Header />

  <!-- Discount Promotion Banner -->
  <DiscountBanner client:load />

  <!-- Interactive Search Bar Drawer -->
  <SearchBar client:load />

  <!-- Main Catalog Grid Section -->
  <main class="bg-gradient-to-b from-[#faf7f8] via-white to-[#faf7f8] py-8">
    <CatalogGrid client:load />
  </main>

  <!-- Footer & Contact buttons -->
  <Footer />
  <FloatingButtons />

  <!-- Interactive Drawers -->
  <CartDrawer client:load />
  <ProfileDrawer client:load />
</Layout>
