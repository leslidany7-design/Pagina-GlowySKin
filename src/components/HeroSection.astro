---
/**
 * HeroSection.astro — Hero with ShaderBackground React island
 */
import ShaderBackground from './react/ShaderBackground';
---

<section class="relative w-full" id="hero">
  <!-- ShaderBackground React island renders here -->
  <ShaderBackground client:visible>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row items-center justify-between relative z-10 min-h-[calc(100vh-80px)] py-12 lg:py-0">

      <!-- Hero Text Content -->
      <div class="w-full lg:w-[42%] lg:pr-6 text-center lg:text-left space-y-6 relative z-10">
        <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-glowy-pink-soft/10 text-[10px] font-bold text-glowy-pink-deep uppercase tracking-[0.2em] border border-glowy-pink-soft/15 animate-fade-up">
          <svg class="w-3 h-3 mr-1.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
          K-Beauty Premium · Chile
        </span>

        <h1 class="serif-title text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[1.08] font-light text-slate-800 animate-fade-up" style="animation-delay: 0.1s">
          Piel radiante,<br />
          <span class="italic font-normal bg-gradient-to-r from-glowy-pink-deep to-[#c44d8e] bg-clip-text text-transparent">Belleza pura</span>,<br />
          Estilo Coreano.
        </h1>

        <p class="text-sm font-light text-slate-600 max-w-lg leading-relaxed animate-fade-up" style="animation-delay: 0.2s">
          Descubre fórmulas revolucionarias nacidas del balance entre naturaleza e innovación. Productos limpios diseñados para nutrir tu piel y revelar tu luminosidad natural.
        </p>

        <div class="flex items-center gap-4 pt-2 flex-wrap animate-fade-up" style="animation-delay: 0.3s">
          <a href="#catalogo" class="px-8 py-3.5 rounded-full bg-slate-900 text-white font-semibold text-xs tracking-widest uppercase hover:bg-slate-800 active:scale-95 transition-all duration-300 soft-shadow-md hover:soft-shadow-lg">
            Explorar Catálogo
          </a>
          <a href="#quiz" class="px-8 py-3.5 rounded-full bg-white/80 backdrop-blur-sm text-slate-800 border border-slate-200/60 font-semibold text-xs tracking-widest uppercase hover:bg-white hover:border-glowy-pink-soft/40 active:scale-95 transition-all duration-300 soft-shadow-sm hover:soft-shadow flex items-center space-x-2">
            <span>Hacer Test de Piel</span>
            <svg class="w-4 h-4 text-glowy-pink-deep" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>

      <!-- HERO IMAGE -->
      <div class="w-full lg:w-[58%] flex items-end justify-center relative select-none mt-8 lg:mt-0 animate-fade-up" style="animation-delay: 0.4s">
        <div class="absolute w-96 h-96 bg-glowy-pink-soft/30 rounded-full blur-[100px] -z-20 animate-soft-pulse"></div>
        <div class="absolute w-80 h-80 bg-glowy-blue-light/25 rounded-full blur-[90px] -z-20 animate-soft-pulse" style="animation-delay: 2s; top: 45%; left: 10%"></div>

        <div class="relative w-full max-w-[620px] lg:max-w-[780px] flex justify-center items-end">
          <img
            src="/images/skincaresinfondo.svg"
            alt="K-Beauty Glow Routine"
            class="w-full h-auto object-contain max-h-[660px] lg:max-h-[820px] transition-transform duration-500 hover:scale-[1.02]"
            style="mask-image: radial-gradient(ellipse 90% 90% at center, black 50%, rgba(0,0,0,0.3) 80%, transparent 100%); -webkit-mask-image: radial-gradient(ellipse 90% 90% at center, black 50%, rgba(0,0,0,0.3) 80%, transparent 100%);"
            loading="eager"
          />

          <!-- Floating product card -->
          <div class="absolute bottom-8 right-2 sm:right-8 lg:-right-10 z-20 bg-white/90 backdrop-blur-md border border-white/70 p-4 sm:p-5 rounded-[2.25rem] shadow-[0_20px_50px_-12px_rgba(0,0,0,0.15)] flex items-center space-x-5 max-w-[320px] sm:max-w-[360px] transition-all duration-300 hover:scale-105 text-left">
            <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-[1.5rem] overflow-hidden bg-slate-50 border border-slate-100 shrink-0">
              <picture>
                <source srcset="/images/Catalogo/8.avif" type="image/avif" />
                <source srcset="/images/Catalogo/8.webp" type="image/webp" />
                <img src="/images/Catalogo/8.webp" alt="KSECRET SEOUL 1988 Serum" class="w-full h-full object-cover" width="80" height="80" loading="eager" />
              </picture>
            </div>
            <div class="flex-grow min-w-0">
              <div class="flex items-center space-x-1.5">
                <span class="text-[9px] font-bold text-glowy-pink-deep bg-glowy-pink-soft/20 px-2.5 py-1 rounded-full uppercase tracking-wider">Bestseller</span>
                <span class="text-[9px] font-medium text-slate-400">Suero</span>
              </div>
              <h4 class="font-bold text-slate-800 text-sm sm:text-base truncate mt-1">SEOUL 1988 Retinal</h4>
              <p class="text-xs sm:text-sm text-slate-900 font-extrabold mt-0.5">$15.490</p>
            </div>
            <button
              data-add-product="p2"
              class="w-10 h-10 sm:w-11 sm:h-11 rounded-full bg-slate-900 hover:bg-glowy-pink-deep text-white flex items-center justify-center transition-all duration-200 active:scale-90 shrink-0"
              aria-label="Añadir al carrito"
            >
              <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            </button>
          </div>
        </div>
      </div>

    </div>
  </ShaderBackground>
</section>

<script>
  import { addToCart } from '../stores/cartStore';
  import { PRODUCTS } from '../data/products';

  // Wire up hero add-to-cart button
  document.querySelector('[data-add-product="p2"]')?.addEventListener('click', (e) => {
    e.stopPropagation();
    const product = PRODUCTS.find(p => p.id === 'p2');
    if (product) addToCart(product);
  });
</script>
