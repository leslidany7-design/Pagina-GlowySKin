---
/**
 * BrandsTicker.astro — Infinite marquee of brand logos (pure CSS)
 */
import { BRANDS } from '../data/products';
---

<section class="relative py-12 z-20 overflow-hidden bg-gradient-to-b from-[#faf7f8] via-[#F0A6C5]/5 to-[#faf7f8] border-y border-white/40">
  <div class="max-w-7xl mx-auto px-4 text-center mb-6">
    <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-[#E963A7]">Marcas que ofrecemos</span>
  </div>
  <div class="ticker-container py-2">
    <div class="animate-ticker flex items-center">
      {/* First set */}
      {BRANDS.map((brand) => (
        <div class="flex-shrink-0 mx-6">
          <span class="font-extrabold tracking-widest text-slate-800 text-xs opacity-65 hover:opacity-100 hover:scale-105 transition-all duration-300 select-none cursor-default whitespace-nowrap">
            {brand}
          </span>
        </div>
      ))}
      {/* Duplicate set for infinite loop */}
      {BRANDS.map((brand) => (
        <div class="flex-shrink-0 mx-6">
          <span class="font-extrabold tracking-widest text-slate-800 text-xs opacity-65 hover:opacity-100 hover:scale-105 transition-all duration-300 select-none cursor-default whitespace-nowrap">
            {brand}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
