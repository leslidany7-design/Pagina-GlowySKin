---
import '../styles/global.css';

interface Props {
  title?: string
  description?: string
}

const {
  title = 'GLOWYSKIN — K-Beauty Premium Chile',
  description = 'Tu portal de confianza para el cuidado facial con raíces en Seúl. Descubre fórmulas revolucionarias de skincare coreano con envío a todo Chile.'
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#E963A7" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/logo-transparente.webp" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/images/logo1.webp" />

    <title>{title}</title>
  </head>
  <body class="relative min-h-screen overflow-x-hidden font-sans bg-[#faf7f8]">
    <slot />
  </body>
</html>
